pipeline {
    agent any
    
    environment {
        // 테스트용 하버 정보 세팅
        REGISTRY = '10.10.0.160'
        PROJECT = 'underlive'
        IMAGE_NAME = 'streaming-app'
        TAG = "${env.BUILD_NUMBER}" // 빌드 번호를 태그로 사용
        HARBOR_CREDS = 'harbor-login' // Jenkins에 등록한 ID
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    // Dockerfiles 폴더 안의 파일을 지정하여 빌드
                    sh "docker build -t ${REGISTRY}/${PROJECT}/${IMAGE_NAME}:${TAG} -f streaming/Dockerfiles/Dockerfile ."
                }
            }
        }

        stage('Harbor Push') {
            steps {
                script {
                    // 하버 로그인 및 푸시
                    docker.withRegistry("https://${REGISTRY}", "${HARBOR_CREDS}") {
                        sh "docker push ${REGISTRY}/${PROJECT}/${IMAGE_NAME}:${TAG}"
                    }
                }
            }
        }

        stage('Update K8S Manifest') {
            steps {
                script {
                    // k8s 폴더 내의 deployment.yaml 이미지 태그를 방금 빌드한 것으로 변경
                    // ArgoCD가 이 변경사항을 감지하여 자동 배포하게 됩니다.
                    sh "sed -i 's|image:.*|image: ${REGISTRY}/${PROJECT}/${IMAGE_NAME}:${TAG}|g' streaming/k8s/deployment.yaml"
                    
                    // 변경된 YAML을 다시 Git에 커밋 & 푸시
                    sh """
                        git config user.email "jenkins@underlive.com"
                        git config user.name "jenkins"
                        git add streaming/k8s/deployment.yaml
                        git commit -m 'image tag update to ${TAG}'
                        git push origin main
                    """
                }
            }
        }
    }
}
